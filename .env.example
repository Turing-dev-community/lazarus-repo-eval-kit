# OpenAI API Key
# Required. The script will not run without this key.
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here...

# How many LLM calls to make at the same time.
# Higher values finish faster but increase the chance of hitting OpenAI rate limits.
# Lower values are safer if you see "rate limit" errors. Default: 4
# LLM_CONCURRENCY=4

# How many times to retry a failed LLM call before giving up.
# Each retry waits longer than the last (exponential backoff).
# Default: 8
# LLM_MAX_RETRIES=8

# Starting wait time (in seconds) before the first retry after a failed LLM call.
# The wait doubles with each attempt: 5s → 10s → 20s → 40s … up to the retry limit.
# Increase this if you frequently hit OpenAI rate limits. Default: 5.0
# LLM_BACKOFF_BASE_DELAY=5.0
